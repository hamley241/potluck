#!/usr/bin/env bash
# Run potluck's test suites. No pytest, no venv setup -- these are deterministic
# harness contracts (no real model calls), so anyone can run them on a fresh
# clone with just `uv` on PATH.
#
#   ./test
#
set -uo pipefail
REPO="$(cd "$(dirname "$0")" && pwd)"
CORE="${CORE_REPO:-$REPO/../harness_core}"
[ -d "$CORE/harness_core" ] || { echo "./test: harness_core not found at $CORE" >&2; exit 2; }
# Fail closed on a missing toolchain, and never fall back to a bare `python3`
# (macOS ships 3.9, which lacks tomllib; this gate needs >=3.11). uv is the only
# toolchain dependency — it fetches Python 3.11 and pydantic — so its absence is
# a no-signal environment failure (exit 2), not a red gate. Name the fix.
command -v uv >/dev/null 2>&1 || {
  echo "./test: uv not found — it is the only toolchain dependency (it fetches" \
       "Python 3.11 and pydantic). Install https://docs.astral.sh/uv/ then re-run." \
       "Exiting 2 (no signal): a missing toolchain is not a test failure." >&2
  exit 2
}
cd "$REPO"

run() {
  # harness_core is a PATH dependency (engine extraction, step 1). The
  # priced C25 risk is that this does not survive a second machine; the
  # published-package migration is named but unbuilt.
  uv run --no-project --python 3.11 --with pydantic \
    env PYTHONPATH="$REPO:$CORE" python3.11 -m "$1"
}

fail=0

# --- packaging checks (ruling, 2026-07-18) ------------------------------
# The suites test the CODE; nothing tested the PACKAGING. A runtime import
# failure of harness_core would leave every suite green while `potluck
# fix` was broken — a review caught exactly that, and these convert the
# catch into a permanent gate layer.
#
# TWO checks, because the claim has two halves and one check implying both
# is observation 004's defect (an earlier draft passed --with-editable,
# supplying the dependency itself, so it could not fail when the
# dependency was undeclared):
#   (1) DECLARATION — static; the only half that catches "a PYTHONPATH was
#       masking it".
#   (2) IMPORTABILITY — dynamic; runs in a stateful uv environment, so it
#       does NOT independently prove the declaration exists.
echo "=== packaging (1/2): harness-core declared in pyproject ==="
# uv provides the 3.11 interpreter (tomllib); never a bare, possibly-3.9 python3.
uv run --no-project --python 3.11 python3.11 - "$REPO/pyproject.toml" <<'PY' || fail=1
import re, sys, tomllib, pathlib
data = tomllib.loads(pathlib.Path(sys.argv[1]).read_text())
names = set()
for d in data.get("project", {}).get("dependencies", []):
    m = re.match(r"^\s*([A-Za-z0-9][A-Za-z0-9._-]*)", d)
    if m:
        names.add(re.sub(r"[-_.]+", "-", m.group(1)).lower())
if "harness-core" not in names:
    print("  [FAIL] harness-core is NOT declared in [project.dependencies];"
          " a PYTHONPATH that happens to supply it would mask this")
    sys.exit(1)
print("  [PASS] harness-core declared")
PY
echo "=== packaging (2/2): potluck doctor imports and runs ==="
if ( cd "$REPO" && uv run --project "$REPO" python -m harness.cli doctor ) >/dev/null 2>&1; then
  echo "  [PASS] potluck doctor imports and runs"
else
  echo "  [FAIL] potluck doctor could not import and run" >&2
  fail=1
fi
echo

# Discover suites from disk so a new harness/test_*.py file is picked up
# automatically -- a hard-coded list is the "new test suite silently skipped"
# failure mode. NUL-delimited + array iteration so paths with spaces or
# other whitespace don't get shell-word-split.
suites=()
while IFS= read -r -d '' f; do
  # harness/foo/test_bar.py -> harness.foo.test_bar
  name="${f%.py}"
  name="${name//\//.}"
  suites+=("$name")
done < <(find harness -name 'test_*.py' -type f -print0 | sort -z)

if [[ ${#suites[@]} -eq 0 ]]; then
  echo "no test suites found under harness/ -- refusing to report ALL SUITES PASS" >&2
  exit 1
fi

for suite in "${suites[@]}"; do
  echo "=== $suite ==="
  run "$suite" || fail=1
  echo
done

if [[ $fail -eq 0 ]]; then
  echo "ALL SUITES PASS"
else
  echo "SOME SUITES FAILED" >&2
fi
exit $fail
